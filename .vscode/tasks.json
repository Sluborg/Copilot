{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Magentic2: Relay Server",
            "type": "shell",
            "command": "@('C:\\Dev\\Copilot\\Magentic2\\env\\.env.dev') | Where-Object { Test-Path $_ } | ForEach-Object { Get-Content $_ | ForEach-Object { if ($_ -and $_ -notmatch '^\\s*#' -and $_ -match '=') { $k,$v = $_ -split '=',2; $k=$k.Trim(); $v=$v.Trim().Trim('\\\"'); if ($k) { Set-Item -Path \"Env:$k\" -Value $v } } } }; $env:CINODE_BASIC_TOKEN=$env:CINODE_API_KEY; $env:TRANSPORT='http'; $env:PORT='3001'; $env:NODE_TLS_REJECT_UNAUTHORIZED='0'; node 'C:\\Dev\\Copilot\\flow-relay-mcp-server\\dist\\index.js'",
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "magentic2-dev"
            }
        },
        {
