{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Agent Locally",
            "dependsOn": [
                "Validate prerequisites",
                "Create resources"
            ],
            "dependsOrder": "sequence"
        },
        {
            "label": "Validate prerequisites",
            "type": "teamsfx",
            "command": "debug-check-prerequisites",
            "args": {
                "prerequisites": [
                    "copilotAccess"
                ]
            }
        },
        {
            "label": "Create resources",
            "type": "teamsfx",
            "command": "provision",
            "args": {
                "env": "local"
            }
        },
        {
            "label": "Install dependencies",
            "type": "shell",
            "command": "npm install",
            "presentation": {
                "reveal": "silent",
                "panel": "new"
            },
            "runOptions": { "runOn": "folderOpen" }
        },
        {
            "label": "Relay Server",
            "type": "shell",
            "command": "@('C:\\Dev\\Magentic2\\env\\.env.dev') | Where-Object { Test-Path $_ } | ForEach-Object { Get-Content $_ | ForEach-Object { if ($_ -and $_ -notmatch '^\\s*#' -and $_ -match '=') { $k,$v = $_ -split '=',2; $k=$k.Trim(); $v=$v.Trim().Trim('\\\"'); if ($k) { Set-Item -Path \"Env:$k\" -Value $v } } } }; $env:TRANSPORT='http'; $env:PORT='3001'; $env:NODE_TLS_REJECT_UNAUTHORIZED='0'; node 'C:\\Dev\\Magentic2\\flow-relay-mcp-server\\dist\\index.js'",
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "dev"
            }
        },
        {
            "label": "Dev Tunnel",
            "type": "shell",
            "command": "devtunnel host magentic2-relay",
            "isBackground": true,
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "dev"
            }
        },
        {
            "label": "Start It All Up",
            "dependsOn": ["Relay Server", "Dev Tunnel"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Patch Tunnel URL",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File scripts\\patch-tunnel-url.ps1",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Relay Health",
            "type": "shell",
            "command": "npm run relay:test:health",
            "options": {
                "cwd": "C:\\Dev\\Magentic2"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "group": "dev"
            }
        },
        {
            "label": "Deploy New Agent Version",
            "type": "shell",
            "command": "npm run generate:env -- dev && npm run compile && npm run patch:pa-spec && npm run patch:plugin-auth && npm run patch:pa-remove-card && npm run patch:agent-version && atk provision --env dev 2>&1 | Tee-Object -FilePath deploy.log",
            "options": {
                "cwd": "C:\\Dev\\Magentic2"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "dev"
            }
        },
        {
            "label": "Smart Deploy (VS Code)",
            "dependsOn": ["Start It All Up", "Patch Tunnel URL", "Relay Health", "Deploy New Agent Version"],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}