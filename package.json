{
  "name": "magentic2",
  "version": "1.430.1",
  "scripts": {
    "compile": "tsp compile ./src/agent/main.tsp --config ./tspconfig.yaml",
    "generate:env": "node scripts/generate-env.js",
    "patch:pa-spec": "node scripts/patch-pa-spec.js",
    "patch:plugin-auth": "node scripts/patch-plugin-auth.js",
    "patch:agent-version": "node scripts/patch-agent-version.js",
    "patch:pa-remove-card": "node scripts/patch-pa-remove-card.js",
    "relay:start": "powershell -ExecutionPolicy Bypass -File \"C:\\\\Dev\\\\Copilot\\\\Magentic2\\\\scripts\\\\start-relay.ps1\"",
    "relay:stop": "powershell -ExecutionPolicy Bypass -File \"C:\\\\Dev\\\\Copilot\\\\Magentic2\\\\scripts\\\\stop-relay.ps1\"",
    "relay:patch:tunnel-url": "powershell -ExecutionPolicy Bypass -File \"C:\\\\Dev\\\\Copilot\\\\Magentic2\\\\scripts\\\\patch-tunnel-url.ps1\"",
    "relay:test:health": "powershell -ExecutionPolicy Bypass -File \"C:\\\\Dev\\\\Copilot\\\\Magentic2\\\\scripts\\\\test-health.ps1\"",
    "deploy:smart": "powershell -ExecutionPolicy Bypass -File \"C:\\\\Dev\\\\Copilot\\\\Magentic2\\\\scripts\\\\deploy-smart.ps1\"",
    "deploy:smart:health": "powershell -ExecutionPolicy Bypass -File \"C:\\\\Dev\\\\Copilot\\\\Magentic2\\\\scripts\\\\deploy-smart.ps1\" -HealthOnly",
    "startup:smart": "powershell -ExecutionPolicy Bypass -File \"C:\\\\Dev\\\\Copilot\\\\Magentic2\\\\scripts\\\\startup-smart.ps1\"",
    "startup:smart:force": "powershell -ExecutionPolicy Bypass -File \"C:\\\\Dev\\\\Copilot\\\\Magentic2\\\\scripts\\\\startup-smart.ps1\" -ForceDeploy",
    "teams:cache:clear": "powershell -ExecutionPolicy Bypass -File \"C:\\\\Dev\\\\Copilot\\\\Magentic2\\\\scripts\\\\clear-teams-cache.ps1\"",
    "app:open:dev": "powershell -NoProfile -Command \"$id=(Get-Content .\\env\\.env.dev | Select-String '^TEAMS_APP_ID=').ToString().Split('=')[1].Trim(); Start-Process ('https://teams.microsoft.com/l/app/' + $id)\"",
    "app:reset:dev": "powershell -NoProfile -Command \"atk uninstall -i false --mode env --env dev --options 'm365-app,app-registration,bot-framework-registration'; npm run compile; npm run patch:pa-spec; npm run patch:plugin-auth; npm run patch:pa-remove-card; atk provision --env dev\""
  },
  "devDependencies": {
    "@microsoft/typespec-m365-copilot": "^1.0.0",
    "@typespec/compiler": "1.5.0",
    "@typespec/http": "1.5.0",
    "@typespec/openapi": "1.5.0",
    "@typespec/openapi3": "1.5.0"
  }
}
