{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.25/MicrosoftTeams.schema.json",
  "manifestVersion": "1.25",
  "version": "1.428.5",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "Stefan Lunneborg",
    "websiteUrl": "https://www.lunneborg.se",
    "privacyUrl": "https://www.lunneborg.se/privacy",
    "termsOfUseUrl": "https://www.lunneborg.se/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "Magentic2${{APP_NAME_SUFFIX}}",
    "full": "Magentic2 Agent for Microsoft 365 Copilot"
  },
  "description": {
    "short": "Self-improving Copilot agent with Power Automate integration.",
    "full": "Magentic2 is a Microsoft 365 Copilot agent created by Stefan Lunneborg. It features dynamic memory, Power Automate actions, and advanced logging for self-improvement. | Release: 1.428.5 @ 2026-04-28 18:38:30 (Swedish time)"
  },
  "accentColor": "#FFFFFF",
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "declarativeAgent",
        "file": "declarativeAgent.json"
      }
    ]
  },
  "composeExtensions": [],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "validDomains": []
}
