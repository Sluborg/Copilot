        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "Dev Tunnel",
      "type": "shell",
      "command": "devtunnel host -p 3001 --allow-anonymous",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "Start Dev",
      "dependsOn": ["Relay Server", "Dev Tunnel"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Patch Tunnel URL",
      "type": "shell",
      "command": "$url = (devtunnel list 2>&1 | Select-String '(https://[a-z0-9]+-3001\\.[a-z]+\\.devtunnels\\.ms)').Matches[0].Value; (Get-Content env\\.env.dev -Raw) -replace '(?m)^PA_APP_SERVER_URL=.*$', \"PA_APP_SERVER_URL=$url\" | Set-Content env\\.env.dev -NoNewline; Write-Host \"Patched .env.dev with $url\" -ForegroundColor Green; Write-Host ''; Write-Host \"Paste to Claude Code:\" -ForegroundColor Cyan; Write-Host \"Update PA_APP_SERVER_URL to $url in src/agent/env.tsp then rebuild\" -ForegroundColor Yellow",
      "options": {
        "cwd": "C:\\Dev\\Copilot\\Magentic2"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Deploy Agent",
      "type": "shell",
      "command": "npm run generate:env -- dev && npm run compile && npm run patch:pa-spec && npm run patch:plugin-auth && npm run patch:agent-version && atk provision --env dev 2>&1 | Tee-Object -FilePath deploy.log",
      "options": {
        "cwd": "C:\\Dev\\Copilot\\Magentic2"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      }
    }
  ]
