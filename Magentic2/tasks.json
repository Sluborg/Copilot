      "isBackground": true,
      "options": {
        "env": {
          "NODE_TLS_REJECT_UNAUTHORIZED": "0",
          "FLOW_WEBHOOK_URL": "https://f97ec0186468e5028db0622bbd110e.5a.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/5ac24948f429454fabd65f9060edc478/triggers/manual/paths/invoke?api-version=1&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=8_E3xI3I2iaIzhy122smoXJi9ksgAwyEYmrlTEN-hqE",
          "TRANSPORT": "http",
